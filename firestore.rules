rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation for ScoreEntry
    function isValidScoreEntry(data) {
      return data.size() == 5
        && 'name' in data && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && 'score' in data && data.score is number && data.score >= 0 && data.score <= 5000
        && 'grade' in data && data.grade is string && data.grade.size() > 0 && data.grade.size() <= 6
        && 'timeTaken' in data && data.timeTaken is number && data.timeTaken >= 0
        && 'timestamp' in data;
    }

    match /leaderboard/{entryId} {
      // Allow any user (even unauthenticated) or anonymous to read the leaderboard
      allow read: if true;
      
      // Allow any user to submit a score safely
      allow create: if isValidScoreEntry(request.resource.data)
                    && request.resource.data.timestamp == request.time;
      
      // Allow no updates or deletes
      allow update, delete: if false;
    }
  }
}
